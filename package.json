{
  "name": "restaurante-las-palmas-pos",
  "private": true,
  "version": "1.4.5",
  "description": "Sistema de Punto de Venta para Restaurante Las Palmas",
  "author": "CyR Las Palmas",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "concurrently -k \"cross-env BROWSER=none npm run dev\" \"wait-on tcp:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "cap:admin": "node scripts/prepare-admin-apk.js",
    "cap:pos": "node scripts/prepare-pos-apk.js"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@google/generative-ai": "^0.24.1",
    "@huggingface/transformers": "^4.2.0",
    "@imgly/background-removal": "^1.7.0",
    "@react-google-maps/api": "^2.20.8",
    "@supabase/supabase-js": "^2.95.3",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "electron-log": "^5.4.4",
    "electron-pos-printer": "^1.3.8",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.563.0",
    "net": "^1.0.2",
    "node-thermal-printer": "^4.6.0",
    "nodemailer": "^8.0.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-simple-keyboard": "^3.8.155",
    "react-to-print": "^3.3.0",
    "recharts": "^3.8.1",
    "xlsx": "^0.18.5",
    "xmldom": "^0.6.0"
  },
  "devDependencies": {
    "@iconify/react": "^6.0.2",
    "@types/dotenv": "^6.1.1",
    "@types/google.maps": "^3.58.1",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^26.7.0",
    "jimp": "^1.6.1",
    "pdf-parse": "^2.4.5",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wait-on": "^9.0.3",
    "yargs": "^18.0.0"
  },
  "build": {
    "appId": "com.restaurante-las-palmas.pos",
    "productName": "Restaurante las Palmas Pos",
    "publish": [
      {
        "provider": "github",
        "owner": "Dany-gt",
        "repo": "Restaurante-Las-Palmas-POS"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "server/**/*",
      "api/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "server/**/*",
      "api/**/*"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "release"
    }
  }
}
